# ===== Roboflow =====
# Consíguela en https://app.roboflow.com -> Settings -> API Keys
ROBOFLOW_API_KEY=tu_api_key_de_roboflow
# Modelo recomendado: detecta casco, chaleco, mascarilla Y la AUSENCIA de ellos.
ROBOFLOW_MODEL_ID=construction-site-safety/27
ROBOFLOW_API_URL=https://serverless.roboflow.com

# Umbrales de inferencia (0-100)
CONFIDENCE_THRESHOLD=40
OVERLAP_THRESHOLD=30

# ===== Reglas de EPP =====
# (Para el modelo construction-site-safety/27. Nombres en minúscula.)
# Clases que SON EPP correcto (presencia = OK).
PPE_CLASSES=hardhat,mask,safety vest,person
# EPP obligatorio que debe estar presente para considerar cumplimiento.
REQUIRED_PPE=hardhat,safety vest
# Clases "negativas" que el modelo emite indicando ausencia (violación directa).
VIOLATION_CLASSES=no-hardhat,no-mask,no-safety vest

# ===== Telegram =====
# Crea un bot con @BotFather -> token. Obtén tu chat_id con @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC-tu_token
TELEGRAM_CHAT_ID=123456789
# Segundos mínimos entre alertas para no hacer spam
ALERT_COOLDOWN_SECONDS=60

# ===== App =====
DATABASE_PATH=epp.db
STORAGE_DIR=storage
